PORT=8787
CHARACTER_BRAIN_TOKEN=replace-with-a-long-random-secret

# OpenAI-compatible upstream, configured only on the server.
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=replace-with-provider-key
AI_MODEL=provider/model-name

# Optional OpenRouter attribution headers.
AI_SITE_URL=
AI_APP_NAME=Character Brain

AI_MAX_TOKENS=1800
AI_TIMEOUT_MS=45000

# Optional JSON object merged into the chat/completions request body.
# Useful for provider-specific parameters. Example for NVIDIA thinking models:
# AI_EXTRA_BODY={"chat_template_kwargs":{"enable_thinking":true},"reasoning_budget":16384}
